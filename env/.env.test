# Test Environment - Used for automated testing
NODE_ENV=test
PORT=3000
LOG_LEVEL=error

# Database - Test Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=test_user
DB_PASSWORD=test_password
DB_DATABASE=nexus_test
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_SSL=false

# Redis - Test Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=test_password
REDIS_DB=1
REDIS_TLS=false

# JWT - Test Secrets
JWT_SECRET=test_jwt_secret_for_testing_only_32chars
JWT_EXPIRES_IN=5m
JWT_REFRESH_SECRET=test_refresh_secret_for_testing_only_32chars
JWT_REFRESH_EXPIRES_IN=1h

# Kafka - Test Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexus-gateway-test
KAFKA_GROUP_ID=nexus-gateway-test-group
KAFKA_SSL=false

# Security - Test Settings
RATE_LIMIT_MAX=10000
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGINS=*

# Monitoring - Disabled for tests
METRICS_ENABLED=false
TRACING_ENABLED=false