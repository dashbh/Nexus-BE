# Nexus Gateway Service Environment Template
# Copy this file to .env.local and customize for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nexus
DB_PASSWORD=your_secure_password_here
DB_DATABASE=nexus_dev
DB_SYNCHRONIZE=true
DB_LOGGING=true
DB_SSL=false

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_TLS=false

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# KAFKA CONFIGURATION
# =============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexus-gateway
KAFKA_GROUP_ID=nexus-gateway-group
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
METRICS_ENABLED=true
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# DOCKER DEVELOPMENT OVERRIDES
# =============================================================================
# These are used when running with Docker Compose
DOCKER_DB_HOST=postgres
DOCKER_REDIS_HOST=redis
DOCKER_KAFKA_BROKERS=kafka:9092